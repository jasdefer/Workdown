{
  "name": "Workdown",
  "image": "mcr.microsoft.com/devcontainers/rust:latest",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates"
      ]
    }
  },
  "mounts": [
    "source=workdown-target,target=${containerWorkspaceFolder}/target,type=volume"
  ],
  "postCreateCommand": "cargo --version && rustc --version",
  "postStartCommand": "sudo chown -R $(whoami) ${containerWorkspaceFolder}/target"
}
